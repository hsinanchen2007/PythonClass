{
    "version": "2.0.0",
    "windows": {
        "options": {
            "shell": {
                "executable": "cmd.exe",
                "args": [
                    "/C",
                    "C:/\"Program Files\"/\"Microsoft Visual Studio\"/2022/Enterprise/Common7/Tools/VsDevCmd.bat",
                    "&&"
                ]
            }
        }
    },
    "tasks": [
        {
            "label": "C++: build active file (cross-platform)",
            "type": "shell",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-O0",
                "-std=c++20",
                "-Wall",
                "-Wextra",
                "-o",
                "/tmp/${workspaceFolderBasename}-vscode-debug",
                "${file}",
                "-pthread"
            ],
            "linux": {
                "command": "/usr/bin/g++",
                "args": [
                    "-fdiagnostics-color=always",
                    "-g",
                    "-O0",
                    "-std=c++20",
                    "-Wall",
                    "-Wextra",
                    "-o",
                    "/tmp/${workspaceFolderBasename}-vscode-debug",
                    "${file}",
                    "-pthread"
                ]
            },
            "osx": {
                "command": "/usr/bin/clang++",
                "args": [
                    "-fcolor-diagnostics",
                    "-fansi-escape-codes",
                    "-g",
                    "-O0",
                    "-std=c++20",
                    "-Wall",
                    "-Wextra",
                    "-arch",
                    "arm64",
                    "-o",
                    "/tmp/${workspaceFolderBasename}-vscode-debug",
                    "${file}",
                    "-pthread"
                ]
            },
            "windows": {
                "command": "cl.exe",
                "args": [
                    "/Zi",
                    "/EHsc",
                    "/std:c++20",
                    "/nologo",
                    "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                    "${file}"
                ]
            },
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc",
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true,
                "showReuseMessage": false
            },
            "runOptions": {
                "reevaluateOnRerun": true
            },
            "detail": "Linux uses GCC, macOS uses Apple Clang, and Windows keeps the existing Visual Studio 2022 MSVC setup."
        }
    ]
}
