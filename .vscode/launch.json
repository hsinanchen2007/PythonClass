{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: debug active file",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "presentation": {
                "hidden": false,
                "order": 1
            }
        },
        {
            "name": "Linux/macOS: build and debug active file (CodeLLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "/tmp/${workspaceFolderBasename}-vscode-debug",
            "args": [],
            "cwd": "${fileDirname}",
            "terminal": "integrated",
            "stopOnEntry": false,
            "preLaunchTask": "C++: build active file (cross-platform)",
            "presentation": {
                "hidden": false,
                "order": 1
            },
            "osx": {
                "env": {
                    "LANG": "zh_TW.UTF-8",
                    "LC_ALL": "zh_TW.UTF-8"
                }
            },
            "windows": {
                "presentation": {
                    "hidden": true,
                    "order": 2
                }
            }
        },
        {
            "name": "Windows: cl.exe build and debug",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "C++: build active file (cross-platform)",
            "presentation": {
                "hidden": true,
                "order": 2
            },
            "windows": {
                "presentation": {
                    "hidden": false,
                    "order": 1
                }
            }
        }
    ]
}
